#!/bin/sh
set -e

case "$1" in
    purge)
        # Remove user and group
        if getent passwd cortex >/dev/null 2>&1; then
            userdel cortex || true
            echo "Removed system user 'cortex'"
        fi

        # Remove data and config directories
        rm -rf /var/lib/cortex
        rm -rf /etc/cortex

        # Reload systemd
        systemctl daemon-reload || true
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        systemctl daemon-reload || true
        ;;
esac

#DEBHELPER#

exit 0
