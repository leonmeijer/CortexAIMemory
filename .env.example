# IndentiaGraph configuration
INDENTIAGRAPH_URI=surrealkv://./.cortex/indentiagraph
INDENTIAGRAPH_USER=root
INDENTIAGRAPH_PASSWORD=root

# Server configuration
SERVER_PORT=8080
WORKSPACE_PATH=.

# NATS message broker (optional — enables inter-process event sync)
# NATS_URL=nats://localhost:4222

# Logging
RUST_LOG=info,project_orchestrator=debug

# Authentication (Google OAuth + JWT)
# Auth is configured in config.yaml (not via env vars).
